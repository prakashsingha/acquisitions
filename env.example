# Generic template — prefer environment-specific files:
#   Development:  cp .env.development.example .env.development
#   Production:   cp .env.production.example .env.production

PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database (see README for dev vs prod)
DATABASE_URL=

# Neon Local (development Docker only — used by neon-local service)
NEON_API_KEY=
NEON_PROJECT_ID=
PARENT_BRANCH_ID=

# Neon Local driver hints (set when using Neon Local proxy)
# NEON_LOCAL=true
# NEON_LOCAL_HOST=neon-local
# NEON_LOCAL_PORT=5432

JWT_SECRET=
ARCJET_KEY=
